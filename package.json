{
  "name": "@inso_web/els-nest",
  "version": "0.4.2",
  "description": "NestJS module и LoggerService для @inso_web/els-client. Drop-in замена встроенного Logger NestJS, nestjs-pino и pino-nestjs. Поддержка app.useLogger() и DI инжекта.",
  "homepage": "https://api.insoweb.ru/els",
  "author": "INSOWEB",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "docs", "examples", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "nest",
    "nest-logger",
    "nestjs-logger",
    "logger",
    "logging",
    "structured-logging",
    "error-tracking",
    "observability",
    "nestjs-pino-alternative",
    "pino-nestjs-alternative",
    "winston-alternative",
    "els",
    "inso",
    "insoweb"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0"
  },
  "dependencies": {
    "@inso_web/els-client": "^0.4.2"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@types/node": "^20.11.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
